<Window x:Class="OrbitBubble.Views.CollectionMergeModeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="集合合併模式"
        Width="360"
        Height="210"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="偵測到你正在拖曳集合泡泡，請選擇合併方式："
                   FontSize="14"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Text="• 展開集合內容：把裡面的檔案攤平合併"
                       Margin="0,0,0,8"/>
            <TextBlock Text="• 保留整個集合：把整顆集合泡泡當子項目放入"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="展開集合內容"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Click="Flatten_Click"/>
            <Button Content="保留整個集合"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Click="Keep_Click"/>
            <Button Content="取消"
                    MinWidth="70"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
