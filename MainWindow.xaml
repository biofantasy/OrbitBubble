<Window x:Class="OrbitBubble.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OrbitBubble"
				WindowState="Normal"
        WindowStyle="None"         
				AllowsTransparency="True"   
				Background="Transparent"     
				Topmost="True"
				ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextHintingMode="Fixed">
	<Grid>
		<Canvas x:Name="MainCanvas" Background="Transparent">

			<Canvas x:Name="AnimationWrapper" 
                    Width="800" Height="800" 
                    Background="Transparent" 
                    RenderTransformOrigin="0.5,0.5">

				<Canvas.RenderTransform>
					<TransformGroup>
						<ScaleTransform x:Name="MainScale" ScaleX="0" ScaleY="0" />
						<RotateTransform x:Name="MainRotate" Angle="0" />
					</TransformGroup>
				</Canvas.RenderTransform>

				<Grid x:Name="CenterHub" 
                      Width="100" Height="100"
                      Canvas.Left="350" Canvas.Top="350"
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center"
                      AllowDrop="True" 
                      DragOver="CenterHub_DragOver" 
                      Drop="CenterHub_Drop"
                      Background="Transparent"
                      MouseLeftButtonDown="CenterHub_MouseLeftButtonDown">

          <Ellipse x:Name="HubBody" Margin="4" IsHitTestVisible="False" Opacity="0.85">
            <Ellipse.Effect>
              <DropShadowEffect x:Name="HubGlowEffect" Color="Cyan" BlurRadius="12" ShadowDepth="0" Opacity="0.65"/>
            </Ellipse.Effect>
            <Ellipse.Fill>
              <RadialGradientBrush Center="0.35,0.3"
                                   GradientOrigin="0.25,0.2"
                                   RadiusX="0.9"
                                   RadiusY="0.9">
                <GradientStop Color="#D0FFFFFF" Offset="0"/>
                <GradientStop x:Name="HubBodyMiddleStop" Color="#AA43B7FF" Offset="0.45"/>
                <GradientStop x:Name="HubBodyEdgeStop" Color="#7A143D73" Offset="1"/>
              </RadialGradientBrush>
            </Ellipse.Fill>
          </Ellipse>

          <Ellipse x:Name="HubHighlight" Width="66"
                   Height="24"
                   VerticalAlignment="Top"
                   Margin="0,10,0,0"
                   Fill="#66FFFFFF"
                   Opacity="0.8"
                   IsHitTestVisible="False">
            <Ellipse.Effect>
              <BlurEffect x:Name="HubHighlightBlur" Radius="7"/>
            </Ellipse.Effect>
          </Ellipse>

					<TextBlock x:Name="HubText" 
                               Text="Root" 
                               Foreground="White" 
                               FontSize="16" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               IsHitTestVisible="False"/>
				</Grid>

			</Canvas>
		</Canvas>
	</Grid>
</Window>
